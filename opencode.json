{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
      "enabled": true
    }
  },
  "plugin": ["opencode-agent-skills"],
  "instructions": [
    ".agents/skills/cjcrsg-hub/SKILL.md",
    ".agents/skills/cjcrsg-hub/project-overview.md",
    ".agents/skills/cjcrsg-hub/architecture.md",
    ".agents/skills/cjcrsg-hub/database.md",
    ".agents/skills/cjcrsg-hub/conventions.md",
    ".agents/skills/cjcrsg-hub/ui-patterns.md",
    ".agents/skills/cjcrsg-hub/convex-patterns.md",
    ".agents/skills/cjcrsg-hub/common-tasks.md",
    ".agents/skills/cjcrsg-hub/quick-reference.md",
    ".agents/skills/shadcn/SKILL.md",
    "docs/TASKS.md",
    "AGENTS.md"
  ]
}
