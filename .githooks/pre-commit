#!/bin/bash
# TDD Pre-commit Hook with Smart Skipping
# This hook runs before each commit to enforce TDD workflow
# Skips heavy checks (tests, lint) for documentation-only changes

set -e

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo "🔍 Running pre-commit checks..."

# Check if this is an exception (emergency, prototype, docs)
EXCEPTION_KEYWORDS="(prototype|spike|hotfix|emergency)"
COMMIT_MSG_FILE="$1"

if [ -f "$COMMIT_MSG_FILE" ]; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    if echo "$COMMIT_MSG" | grep -qiE "$EXCEPTION_KEYWORDS"; then
        echo -e "${YELLOW}⚠️  Exception detected: Skipping TDD checks${NC}"
        echo "   Commit message: $COMMIT_MSG"
        exit 0
    fi
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

# If no files staged, exit early
if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}✅ No files staged${NC}"
    exit 0
fi

# Check if any code files are staged
# Code files: .ts, .tsx, .js, .jsx, .css (including convex/schema.ts and all convex/ files)
# Non-code: .md, .txt, .json (except convex/schema.json), .yml, .yaml, images, configs

HAS_CODE_FILES=false
HAS_CONVEX_SCHEMA=false
HAS_MUTATIONS=false
HAS_QUERIES=false
HAS_SHARED_COMPONENTS=false

for file in $STAGED_FILES; do
    # Check for code files
    if echo "$file" | grep -qE '\.(ts|tsx|js|jsx|css)$'; then
        HAS_CODE_FILES=true
        
        # Check for convex schema changes
        if echo "$file" | grep -q '^convex/schema\.ts$'; then
            HAS_CONVEX_SCHEMA=true
        fi
        
        # Check for mutations
        if echo "$file" | grep -q 'convex/.*/mutations\.ts$'; then
            HAS_MUTATIONS=true
        fi
        
        # Check for queries
        if echo "$file" | grep -q 'convex/.*/queries\.ts$'; then
            HAS_QUERIES=true
        fi
        
        # Check for shared components
        if echo "$file" | grep -qE '^src/components/ui/.*\.tsx$'; then
            HAS_SHARED_COMPONENTS=true
        fi
    fi
done

# If only non-code files are staged, skip heavy checks
if [ "$HAS_CODE_FILES" = false ]; then
    echo -e "${BLUE}📄 Documentation/config-only changes detected - skipping code checks${NC}"
    echo ""
    echo "   Staged files:"
    echo "$STAGED_FILES" | sed 's/^/     - /'
    echo ""
    
    # Still remind about changelog for documentation changes
    if echo "$STAGED_FILES" | grep -qE '\.(md|txt)$'; then
        echo -e "${YELLOW}💡 Reminder: Update CHANGELOG.md if this is a user-facing change${NC}"
    fi
    
    exit 0
fi

# From here on, we have code files - run full checks
echo -e "${BLUE}📝 Code files detected - running full quality checks${NC}"
echo ""

# Show which code files are being committed
CODE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx|css)$' || true)
if [ -n "$CODE_FILES" ]; then
    echo "   Code files:"
    echo "$CODE_FILES" | head -10 | sed 's/^/     - /'
    CODE_COUNT=$(echo "$CODE_FILES" | wc -l)
    if [ "$CODE_COUNT" -gt 10 ]; then
        echo "     ... and $((CODE_COUNT - 10)) more"
    fi
    echo ""
fi

# Check for new mutations without tests
if [ "$HAS_MUTATIONS" = true ]; then
    echo "📦 New mutations detected..."
    
    MUTATION_FILES=$(echo "$STAGED_FILES" | grep 'convex/.*/mutations.ts' || true)
    
    for file in $MUTATION_FILES; do
        # Extract feature name from path (e.g., convex/eventTypes/mutations.ts → eventTypes)
        FEATURE=$(echo "$file" | sed 's|convex/||' | sed 's|/mutations.ts||')
        
        # Check if corresponding test file exists
        TEST_FILE="tests/unit/convex/$FEATURE/mutations.test.ts"
        
        if [ ! -f "$TEST_FILE" ]; then
            echo -e "${YELLOW}⚠️  Warning: New mutations in $file but no test file found${NC}"
            echo "   Expected: $TEST_FILE"
            echo ""
            echo "   TDD Reminder: Consider writing tests first next time!"
            echo ""
        else
            echo -e "${GREEN}✅ Test file exists: $TEST_FILE${NC}"
        fi
    done
fi

# Check for new queries without tests
if [ "$HAS_QUERIES" = true ]; then
    echo "📦 New queries detected..."
    
    QUERY_FILES=$(echo "$STAGED_FILES" | grep 'convex/.*/queries.ts' || true)
    
    for file in $QUERY_FILES; do
        FEATURE=$(echo "$file" | sed 's|convex/||' | sed 's|/queries.ts||')
        TEST_FILE="tests/unit/convex/$FEATURE/queries.test.ts"
        
        if [ ! -f "$TEST_FILE" ]; then
            echo -e "${YELLOW}⚠️  Warning: New queries in $file but no test file found${NC}"
            echo "   Expected: $TEST_FILE"
            echo ""
            echo "   TDD Reminder: Consider writing tests first next time!"
            echo ""
        else
            echo -e "${GREEN}✅ Test file exists: $TEST_FILE${NC}"
        fi
    done
fi

# Check for new shared components without tests
if [ "$HAS_SHARED_COMPONENTS" = true ]; then
    echo "🧩 New shared components detected..."
    
    COMPONENT_FILES=$(echo "$STAGED_FILES" | grep -E '^src/components/ui/.*\.tsx$' || true)
    
    for file in $COMPONENT_FILES; do
        # Extract component name
        COMPONENT=$(basename "$file" .tsx | tr '[:upper:]' '[:lower:]')
        TEST_FILE="tests/unit/components/$COMPONENT.test.tsx"
        
        if [ ! -f "$TEST_FILE" ]; then
            echo -e "${YELLOW}⚠️  Warning: New component $file but no test file found${NC}"
            echo "   Expected: $TEST_FILE"
            echo ""
            echo "   TDD Reminder: Shared components should have tests!"
            echo ""
        else
            echo -e "${GREEN}✅ Test file exists: $TEST_FILE${NC}"
        fi
    done
fi

# Special notice for schema changes
if [ "$HAS_CONVEX_SCHEMA" = true ]; then
    echo -e "${BLUE}🗄️  Convex schema changes detected${NC}"
    echo "   Make sure to update related tests if schema changes affect queries/mutations"
    echo ""
fi

# Run tests
echo ""
echo "🧪 Running test suite..."

if ! pnpm test > /tmp/test_output.log 2>&1; then
    echo -e "${RED}❌ Tests failed!${NC}"
    echo ""
    echo "   Test output:"
    tail -20 /tmp/test_output.log | sed 's/^/   /'
    echo ""
    echo "   Run 'pnpm test' to see full details."
    rm -f /tmp/test_output.log
    exit 1
else
    echo -e "${GREEN}✅ All tests pass${NC}"
    rm -f /tmp/test_output.log
fi

# Run lint
echo ""
echo "🔍 Running linter..."

if ! pnpm lint > /tmp/lint_output.log 2>&1; then
    echo -e "${RED}❌ Linting failed!${NC}"
    echo ""
    echo "   Lint output:"
    tail -20 /tmp/lint_output.log | sed 's/^/   /'
    echo ""
    echo "   Run 'pnpm lint' to see full details."
    rm -f /tmp/lint_output.log
    exit 1
else
    echo -e "${GREEN}✅ Linting passed${NC}"
    rm -f /tmp/lint_output.log
fi

echo ""
echo -e "${GREEN}✅ Pre-commit checks passed!${NC}"
echo ""

exit 0
