# =============================================================================
# CJCRSG-Hub Environment Variables
# =============================================================================
# Copy this file to .env.local and update values for your setup
# DO NOT commit .env.local to version control (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Convex Configuration
# -----------------------------------------------------------------------------

# Convex WebSocket URL for real-time data sync
# This is automatically set when running `pnpm dlx convex dev`
VITE_CONVEX_URL=http://127.0.0.1:3210

# Your frontend URL (used for OAuth callbacks and site configuration)
# Change this in production to your actual domain (e.g., https://your-church.com)
CONVEX_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OPTIONAL: OAuth Authentication
# -----------------------------------------------------------------------------
# For detailed OAuth setup instructions, see docs/OAUTH_SETUP.md
#
# Google OAuth credentials from Google Cloud Console
# AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=GOCSPX-your-client-secret
#
# Facebook OAuth credentials from Facebook Developers
# AUTH_FACEBOOK_ID=your-facebook-app-id
# AUTH_FACEBOOK_SECRET=your-facebook-app-secret
#
# Set these in Convex dashboard (NOT in .env.local for security):
#   pnpm dlx convex env set AUTH_GOOGLE_ID your-client-id
#   pnpm dlx convex env set AUTH_GOOGLE_SECRET your-client-secret
#   pnpm dlx convex env set AUTH_FACEBOOK_ID your-app-id
#   pnpm dlx convex env set AUTH_FACEBOOK_SECRET your-app-secret
#
# OAuth Redirect URIs to configure:
#   Development: http://localhost:3000/api/auth/callback/google
#   Production:  https://your-domain.com/api/auth/callback/google

# -----------------------------------------------------------------------------
# Convex Auth (Auto-Generated, Do Not Modify)
# -----------------------------------------------------------------------------
# These are automatically managed by Convex Auth
# Do not manually set these unless you know what you're doing
# VITE_CONVEX_SITE_URL=http://127.0.0.1:3211
# CONVEX_DEPLOYMENT=anonymous:anonymous-cjcrsg-hub

# -----------------------------------------------------------------------------
# Future: Additional Configuration
# -----------------------------------------------------------------------------
# Add any custom environment variables below
# Example: Analytics, third-party integrations, feature flags
